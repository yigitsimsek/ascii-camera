#!/bin/zsh
set -eu

APP="/Applications/ASCII Camera.app"
BUNDLE_ID="com.yigit.asciicamera"
JOB="gui/$(id -u)/$BUNDLE_ID"
OBS_EXTENSION_ID="com.obsproject.obs-studio.mac-camera-extension"
COMMAND="${1:-start}"

obs_extension_state() {
  local line
  line="$(systemextensionsctl list 2>/dev/null | grep -F "$OBS_EXTENSION_ID" || true)"
  if [[ "$line" == *"[activated enabled]"* ]]; then
    echo "activated"
  elif [[ "$line" == *"waiting for user"* ]]; then
    echo "approval pending"
  elif [[ -n "$line" ]]; then
    echo "registered but unavailable"
  else
    echo "not activated"
  fi
}

case "$COMMAND" in
  start)
    if [[ ! -d "$APP" ]]; then
      echo "ASCII Camera is not installed. Run scripts/install.sh from the repository first."
      exit 1
    fi
    EXTENSION_STATE="$(obs_extension_state)"
    if [[ "$EXTENSION_STATE" != "activated" ]]; then
      echo "OBS Camera Extension: $EXTENSION_STATE."
      if [[ "$EXTENSION_STATE" == "approval pending" ]]; then
        echo "Approve OBS Virtual Camera under System Settings > General > Login Items & Extensions > Camera Extensions."
      else
        echo "Run: open -a OBS --args --startvirtualcam"
        echo "Approve the Camera Extension if macOS prompts you."
      fi
      echo "Restart OBS and start its virtual camera once; then quit OBS and run asciicam again."
      exit 1
    fi
    if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
      echo "ASCII Camera is already running."
      exit 0
    fi
    if launchctl print "$JOB" >/dev/null 2>&1; then
      launchctl kickstart -k "$JOB"
    else
      # The separately signed native Camera Extension build does not use this LaunchAgent.
      open -gj -b "$BUNDLE_ID"
    fi
    for _ in {1..30}; do
      if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
        echo "ASCII Camera is running at 240 columns. Select ‘OBS Virtual Camera’ in your calling app."
        exit 0
      fi
      sleep 0.1
    done
    echo "ASCII Camera did not start. Run ‘asciicam logs’ for diagnostics."
    exit 1
    ;;
  stop)
    if launchctl print "$JOB" >/dev/null 2>&1; then
      launchctl kill SIGTERM "$JOB" >/dev/null 2>&1 || true
      echo "ASCII Camera stopped."
    elif pkill -x "ASCII Camera" >/dev/null 2>&1; then
      echo "ASCII Camera stopped."
    else
      echo "ASCII Camera was not running."
    fi
    ;;
  status)
    if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
      echo "host: running"
    else
      echo "host: stopped"
    fi
    echo "modern driver: $(obs_extension_state)"
    if systemextensionsctl list 2>/dev/null | grep -q "com.yigit.asciicamera.extension"; then
      systemextensionsctl list 2>/dev/null | grep "com.yigit.asciicamera.extension"
    fi
    ;;
  logs)
    exec log stream --style compact --level info --predicate 'subsystem BEGINSWITH "com.yigit.asciicamera"'
    ;;
  *)
    echo "Usage: asciicam [start|stop|status|logs]"
    exit 2
    ;;
esac
