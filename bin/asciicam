#!/bin/zsh
set -eu

APP="/Applications/ASCII Camera.app"
BUNDLE_ID="com.yigit.asciicamera"
JOB="gui/$(id -u)/$BUNDLE_ID"
COMMAND="${1:-start}"

case "$COMMAND" in
  start)
    if [[ ! -d "$APP" ]]; then
      echo "ASCII Camera is not installed. Run scripts/install.sh from the repository first."
      exit 1
    fi
    if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
      echo "ASCII Camera is already running."
      exit 0
    fi
    if launchctl print "$JOB" >/dev/null 2>&1; then
      launchctl kickstart -k "$JOB"
    else
      # The paid Camera Extension build does not use the legacy LaunchAgent.
      open -gj -b "$BUNDLE_ID"
    fi
    for _ in {1..30}; do
      if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
        if launchctl print "$JOB" >/dev/null 2>&1; then
          echo "ASCII Camera is running at 240 columns. Select ‘OBS Virtual Camera’ in your calling app."
        else
          echo "ASCII Camera is running at 240 columns. Select ‘ASCII Camera’ in your calling app."
        fi
        exit 0
      fi
      sleep 0.1
    done
    echo "ASCII Camera did not start. Run ‘asciicam logs’ for diagnostics."
    exit 1
    ;;
  stop)
    if launchctl print "$JOB" >/dev/null 2>&1; then
      launchctl kill SIGTERM "$JOB" >/dev/null 2>&1 || true
      echo "ASCII Camera stopped."
    elif pkill -x "ASCII Camera" >/dev/null 2>&1; then
      echo "ASCII Camera stopped."
    else
      echo "ASCII Camera was not running."
    fi
    ;;
  status)
    if pgrep -x "ASCII Camera" >/dev/null 2>&1; then
      echo "host: running"
    else
      echo "host: stopped"
    fi
    if [[ -d "/Library/CoreMediaIO/Plug-Ins/DAL/obs-mac-virtualcam.plugin" ]]; then
      echo "legacy driver: installed"
    else
      echo "legacy driver: not installed"
    fi
    if systemextensionsctl list 2>/dev/null | grep -q "com.yigit.asciicamera.extension"; then
      systemextensionsctl list 2>/dev/null | grep "com.yigit.asciicamera.extension"
    fi
    ;;
  logs)
    exec log stream --style compact --level info --predicate 'subsystem BEGINSWITH "com.yigit.asciicamera"'
    ;;
  *)
    echo "Usage: asciicam [start|stop|status|logs]"
    exit 2
    ;;
esac
